{
  "name": "konvajs-room-designer",
  "version": "0.1.0",
  "description": "A React room designer component built with Konva.js",
  "author": "Jarred Cain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarredcain/konvajs-room-designer.git"
  },
  "keywords": [
    "react",
    "konva",
    "room-designer",
    "floor-plan",
    "canvas"
  ],
  "type": "module",
  "main": "dist/room-designer.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/room-designer.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": false,
  "peerDependencies": {
    "konva": "^9.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-konva": "^18.0.0"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "nanoid": "^5.1.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "konva": "^9.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8"
  }
}
